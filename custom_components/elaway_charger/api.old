"""Elaway API Client handling Auth0 web-flow simulation identical to the iOS/Android mobile app."""
from __future__ import annotations

import logging
import time
import json
import aiohttp
import traceback
import hashlib
import base64
import secrets
from urllib.parse import urlparse, parse_qs, urljoin

_LOGGER = logging.getLogger(__name__)

REDIRECT_URI = "io.elaway.no.app://auth.elaway.io/ios/io.elaway.no.app/callback"
ELAWAY_AUTH_URL = "https://auth.elaway.io/authorize"
ELAWAY_TOKEN_URL = "https://auth.elaway.io/oauth/token"
AMPECO_BASE_URL = "https://no.eu-elaway.charge.ampeco.tech/api/v1/app"

# Korrekte systemnøkler verifisert direkte fra appens faktiske nettverkstrafikk
LIVE_AUTH0_CLIENT_ID = "M2kaE3PPzgBquzt0EuJd7zeCJms7mOcu"
LIVE_AMPECO_CLIENT_ID = "elaway-mobile-app"

class ElawayAPI:
    """API Client wrapper simulating the official mobile app web authentication flow."""

    def __init__(self, username=None, password=None, ampeco_api_url=None):
        """Initialize the API client structural requirements with user credentials only."""
        self.username = username
        self.password = password
        
        self.client_id = LIVE_AUTH0_CLIENT_ID
        self.elaway_client_id = LIVE_AMPECO_CLIENT_ID
        
        self.ampeco_base_url = ampeco_api_url or AMPECO_BASE_URL
        self.ampeco_token_url = f"{self.ampeco_base_url}/oauth/token"
        
        self.ampeco_token = None
        self.expires_at = 0
        self.evse_id = None 

    def _generate_pkce_pair(self) -> tuple[str, str]:
        """Genererer en kryptografisk verifier og challenge for PKCE."""
        verifier = secrets.token_urlsafe(32)
        sha256_hash = hashlib.sha256(verifier.encode('utf-8')).digest()
        challenge = base64.urlsafe_b64encode(sha256_hash).decode('utf-8').replace('=', '').replace('+', '-').replace('/', '_')
        return verifier, challenge

    async def async_get_valid_credentials(self) -> str:
        """Main method to retrieve a valid token, handling token expiration logic."""
        if self.ampeco_token and self.expires_at > time.time():
            return self.ampeco_token

        try:
            return await self._perform_login()
        except Exception as e:
            _LOGGER.error("CRITICAL ERROR IN API.PY LOGIN SEQUENCE: %s", traceback.format_exc())
            raise Exception(str(e))

    async def _perform_login(self) -> str:
        """Simulerer en iPhone som logger inn på Auth0 og veksler til et gyldig Ampeco-token."""
        _LOGGER.info("Starter helautomatisk mobil-pålogging mot Auth0...")
        
        headers = {
            "User-Agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Mobile/15E148",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
            "Accept-Language": "nb-NO,nb;q=0.9,no;q=0.8,en-US;q=0.7,en;q=0.6"
        }
        
        local_state = secrets.token_urlsafe(16)
        code_verifier, code_challenge = self._generate_pkce_pair()
        
        async with aiohttp.ClientSession(headers=headers, cookie_jar=aiohttp.CookieJar(unsafe=True)) as session:
            
            # STEG 1: Start Auth0-sesjon
            auth_url = (
                f"{ELAWAY_AUTH_URL}?response_type=code"
                f"&client_id={self.client_id}"
                f"&redirect_uri={REDIRECT_URI}"
                f"&scope=openid%20profile%20email%20offline_access"
                f"&state={local_state}"
                f"&code_challenge={code_challenge}"
                f"&code_challenge_method=S256"
            )
            
            async with session.get(auth_url, allow_redirects=True) as resp:
                if resp.status != 200:
                    raise Exception(f"Auth0-initiering feilet: {resp.status}")
                final_url = str(resp.url)
                actual_state = parse_qs(urlparse(final_url).query).get("state", [local_state])[0]

            # STEG 2: Post e-post og passord til Auth0
            login_url = f"https://auth.elaway.io/u/login?state={actual_state}"
            payload = {
                "state": actual_state,
                "username": self.username,
                "password": self.password,
                "action": "default"
            }

            async with session.post(login_url, data=payload, allow_redirects=False) as resp:
                if resp.status not in (301, 302):
                    raise Exception("Auth0 avviste innloggingen. Vennligst sjekk e-post og passord.")
                location = resp.headers.get("Location", "")

            # STEG 3: Hent autorisasjonskode
            if "code=" not in location:
                async with session.get(urljoin("https://auth.elaway.io", location), allow_redirects=False) as resp:
                    location = resp.headers.get("Location", "")

            code = parse_qs(urlparse(location).query).get("code", [None])[0]
            if not code:
                raise Exception("Kunne ikke fange opp autorisasjonskoden fra Auth0.")

            # STEG 4: Hent ut de rå Auth0-tokenene
            token_payload = {
                "grant_type": "authorization_code",
                "client_id": self.client_id,
                "redirect_uri": REDIRECT_URI,
                "code": code,
                "code_verifier": code_verifier
            }

            async with session.post(ELAWAY_TOKEN_URL, json=token_payload) as resp:
                if resp.status != 200:
                    raise Exception(f"Auth0 tokenutveksling feilet: {await resp.text()}")
                
                auth0_data = await resp.json()
                access_token = auth0_data.get("access_token")
                id_token = auth0_data.get("id_token")

            # STEG 5: Det offisielle skjemabaserte tokenbyttet mot Ampeco hentet fra HAR-filen din.
            token_bundle = {
                "accessToken": access_token,
                "idToken": id_token,
                "scope": "openid profile email offline_access",
                "expiresIn": 86400,
                "tokenType": "Bearer"
            }

            # Nøkkelen til suksess: Vi sender kun elaway-mobile-app UTEN client_secret over form-urlencoded!
            ampeco_payload = {
                "grant_type": "third-party",
                "type": "auth0",
                "token": json.dumps(token_bundle),
                "client_id": self.elaway_client_id
            }
            
            _LOGGER.info("Utfører det reelle Ampeco-tokenbyttet identisk med appens nettverkstrafikk...")
            async with session.post(self.ampeco_token_url, data=ampeco_payload) as resp:
                if resp.status != 200:
                    error_details = await resp.text()
                    raise Exception(f"Ampeco avviste tokenbyttet: {error_details}")
                
                data = await resp.json()
                self.ampeco_token = data.get("access_token")
                self.expires_at = time.time() + data.get("expires_in", 3600)
                
                _LOGGER.info("Ampeco-autentisering vellykket!")
                return self.ampeco_token

    async def async_patch_charger(self, charger_id: str, payload: dict) -> bool:
        """Patch settings on a specific charge point."""
        token = await self.async_get_valid_credentials()
        url = f"{self.ampeco_base_url}/personal/charge-points/{charger_id}"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        async with aiohttp.ClientSession() as session:
            async with session.patch(url, headers=headers, json=payload) as resp:
                return resp.status in [200, 204]

    async def async_reboot_charger(self, charger_id: str) -> bool:
        """Send reboot command to a specific charge point."""
        token = await self.async_get_valid_credentials()
        url = f"{self.ampeco_base_url}/personal/charge-points/{charger_id}/reboot"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        async with aiohttp.ClientSession() as session:
            async with session.post(url, headers=headers, json={}) as resp:
                return resp.status in [200, 201, 202, 204]

    async def async_start_session(self, evse_id: str) -> bool:
        """Start a charging session on a specific EVSE."""
        token = await self.async_get_valid_credentials()
        url = f"{self.ampeco_base_url}/session/start"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        payload = {"evseId": int(evse_id)}
        async with aiohttp.ClientSession() as session:
            async with session.post(url, headers=headers, json=payload) as resp:
                return resp.status in [200, 201, 202]

    async def async_stop_session(self, session_id: str) -> bool:
        """Stop a specific charging session."""
        token = await self.async_get_valid_credentials()
        url = f"{self.ampeco_base_url}/session/{session_id}/end"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        async with aiohttp.ClientSession() as session:
            async with session.post(url, headers=headers) as resp:
                return resp.status in [200, 202, 204]

    async def async_patch_settings(self, settings: dict) -> None:
        """Transmit parameter adjustments over a secure HTTP PATCH query structure to the hardware."""
        token = await self.async_get_valid_credentials()
        if not self.evse_id:
            raise Exception("Cannot update hardware configurations: EVSE identification key context is absent.")
        url = f"{self.ampeco_base_url}/evses/{self.evse_id}"
        headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json", "Accept": "application/json"}
        async with aiohttp.ClientSession() as session:
            async with session.patch(url, headers=headers, json=settings) as resp:
                if resp.status not in (200, 204):
                    raise Exception(f"Hardware modification failure: {resp.status}")
